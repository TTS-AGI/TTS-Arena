# Router auth — callers must send `Authorization: Bearer <ROUTER_API_KEY>`.
# Leave unset for open local dev.
ROUTER_API_KEY=

# Port the router listens on (default 8080).
PORT=8080

# Comma-separated private provider plugin packages to load at boot, e.g.
# PROVIDER_PLUGINS=@ttsa-private/acme,@ttsa-private/beta
PROVIDER_PLUGINS=

# ── Provider credentials ──────────────────────────────────────────────
# ElevenLabs
ELEVENLABS_API_KEY=

# MiniMax (Hailuo)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
