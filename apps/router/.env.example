# Router auth — callers must send `Authorization: Bearer <ROUTER_API_KEY>`.
# Leave unset for open local dev.
ROUTER_API_KEY=

# Port the router listens on (default 8080).
PORT=8080

# Comma-separated private provider plugin packages to load at boot, e.g.
# PROVIDER_PLUGINS=@ttsa-private/acme,@ttsa-private/beta
PROVIDER_PLUGINS=

# ── Public provider credentials (each activates when its key is present) ──
# ElevenLabs
ELEVENLABS_API_KEY=
# MiniMax (Hailuo)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# Cartesia
CARTESIA_API_KEY=
# Hume
HUME_API_KEY=
# Typecast
TYPECAST_API_KEY=
# Gradium
GRADIUM_API_KEY=
# Resemble Chatterbox
CHATTERBOX_API_KEY=
# Inworld
INWORLD_API_KEY=
# MARS (camb.ai)
MARS_API_KEY=
# Tontaube
TONTAUBE_API_KEY=

# ── Private providers ─────────────────────────────────────────────────
# Loaded only when the private plugin package is listed in PROVIDER_PLUGINS
# (e.g. PROVIDER_PLUGINS=@ttsa-private/providers). Their endpoints live in
# secrets, so the keys/URLs are required for them to activate:
#   PARMESAN_BASE_URL, PARMESAN_API_KEY
#   LANTERNFISH_API_URL, LANTERNFISH_API_KEY, LANTERNFISH_MODEL, LANTERNFISH_REFERENCE_ID
#   VOCU_API_KEY, VOCU_BASE_URL
#   NLS_BASE_URL, NLS_TOKEN
