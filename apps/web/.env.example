# ── Database ──────────────────────────────────────────────────────────
# Postgres connection string (external VPS in prod, local Postgres in dev).
DATABASE_URL=postgresql://user:password@localhost:5432/tts_arena

# ── Hugging Face OAuth ────────────────────────────────────────────────
HF_OAUTH_CLIENT_ID=
HF_OAUTH_CLIENT_SECRET=
# Public base URL of the web app (for the OAuth redirect), e.g.
# https://arena.example.com  — defaults to http://localhost:3000 in dev.
APP_URL=http://localhost:3000

# Secret used to sign the session cookie (32+ random bytes).
SESSION_SECRET=

# Comma-separated admin usernames (optional).
ADMIN_USERS=

# ── TTS router ────────────────────────────────────────────────────────
# Base URL of the router service and its bearer key.
ROUTER_URL=http://localhost:8080
ROUTER_API_KEY=
