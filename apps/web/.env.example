# ── Database ──────────────────────────────────────────────────────────
# Path to the SQLite database file (a single file the host/bucket persists).
# Defaults to ./tts_arena.db when unset.
SQLITE_PATH=./tts_arena.db

# ── Hugging Face OAuth ────────────────────────────────────────────────
HF_OAUTH_CLIENT_ID=
HF_OAUTH_CLIENT_SECRET=
# Public base URL of the web app (for the OAuth redirect), e.g.
# https://arena.example.com  — defaults to http://localhost:3000 in dev.
APP_URL=http://localhost:3000

# Secret used to sign the session cookie (32+ random bytes).
SESSION_SECRET=

# Comma-separated admin usernames (lowercased match). Grants /admin access.
ADMIN_USERS=mrfakename

# Anti-fraud emergency kill switch. Set to 1 to disable all vote risk-scoring,
# the captcha gate, and the security sweep (e.g. if false positives spike).
SECURITY_DISABLED=

# ── TTS router ────────────────────────────────────────────────────────
# Base URL of the router service and its bearer key.
ROUTER_URL=http://localhost:8080
ROUTER_API_KEY=
